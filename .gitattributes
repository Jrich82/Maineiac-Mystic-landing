# Normalize line endings: LF in the repo, native on checkout.
* text=auto eol=lf

# Explicit text files
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.svg    text eol=lf

# Windows scripts
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary
*.jpg    binary
*.jpeg   binary
*.png    binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
